<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd">

    <bean id="sqlSession" class="org.mybatis.spring.SqlSessionFactoryBean">
        <property name="dataSource" ref="dataSource" />
        <property name="configLocation" value="classpath:/egovframework/sqlmap/example/sql-mapper-config.xml" />
        <property name="mapperLocations" value="classpath:/egovframework/sqlmap/example/mappers/*.xml" />
    </bean>

    <bean class="org.egovframe.rte.psl.dataaccess.mapper.MapperConfigurer">
        <property name="basePackage" value="egovframework.example.sample.service.impl" />
    </bean>

    <bean id="equipmentMapper" class="org.mybatis.spring.mapper.MapperFactoryBean">
        <property name="mapperInterface" value="egovframework.example.equipment.EquipmentMapper" />
        <property name="sqlSessionFactory" ref="sqlSession" />
    </bean>

</beans>